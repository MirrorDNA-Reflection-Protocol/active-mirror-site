{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "active-mirror-site-gateway",
  "account_id": "c67a8591dff0a1b3681da50540530fc3",
  "main": "src/index.js",
  "compatibility_date": "2026-06-21",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "gateway.activemirror.ai",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "ratelimits": [
    {
      "name": "MIRROR_SESSION_RATE_LIMITER",
      "namespace_id": "26062601",
      "simple": {
        "limit": 12,
        "period": 60
      }
    },
    {
      "name": "MIRROR_NETWORK_RATE_LIMITER",
      "namespace_id": "26062602",
      "simple": {
        "limit": 36,
        "period": 60
      }
    }
  ],
  "vars": {
    "MIRROR_BRIDGE_URL": "https://proxy.activemirror.ai",
    "MIRROR_REFLECTION_PRIMARY": "bridge",
    "MIRROR_CHAT_PRIMARY": "bridge",
    "MIRROR_MEDIA_PRIMARY": "gemini",
    "PROVIDER_TIMEOUT_MS": "25000",
    "ANTHROPIC_REFLECTION_MODEL": "claude-sonnet-4-5",
    "OPENAI_REFLECTION_MODEL": "gpt-5.5",
    "OPENAI_FAST_MODEL": "gpt-5.4-mini",
    "GEMINI_MEDIA_MODEL": "gemini-3.5-flash",
    "GEMINI_IMAGE_MODEL": "gemini-3.1-flash-image",
    "GEMINI_VIDEO_MODEL": "veo-3.1-fast-generate-preview",
    "MIRROR_RATE_WINDOW_SECONDS": "60",
    "MIRROR_SESSION_WINDOW_LIMIT": "12",
    "MIRROR_NETWORK_WINDOW_LIMIT": "36",
    "MIRROR_SESSION_DAILY_LIMIT": "80",
    "MIRROR_NETWORK_DAILY_LIMIT": "500",
    "RATE_LIMIT_FAIL_CLOSED": "true",
    "EVENT_RATE_WINDOW_SECONDS": "60",
    "EVENT_SESSION_WINDOW_LIMIT": "90",
    "EVENT_NETWORK_WINDOW_LIMIT": "240"
  }
}
