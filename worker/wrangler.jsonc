{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "active-mirror-site-gateway",
  "account_id": "c67a8591dff0a1b3681da50540530fc3",
  "main": "src/index.js",
  "compatibility_date": "2026-06-21",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "gateway.activemirror.ai",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "ratelimits": [
    {
      "name": "MIRROR_SESSION_RATE_LIMITER",
      "namespace_id": "26062601",
      "simple": {
        "limit": 12,
        "period": 60
      }
    },
    {
      "name": "MIRROR_NETWORK_RATE_LIMITER",
      "namespace_id": "26062602",
      "simple": {
        "limit": 36,
        "period": 60
      }
    }
  ],
  "vars": {
    "OPENAI_REFLECTION_MODEL": "gpt-5.5",
    "OPENAI_FAST_MODEL": "gpt-5.4-mini",
    "GEMINI_MEDIA_MODEL": "gemini-3.5-flash",
    "GEMINI_IMAGE_MODEL": "gemini-3.1-flash-image",
    "GEMINI_VIDEO_MODEL": "veo-3.1-fast-generate-preview"
  }
}
