{
  "name": "active-mirror-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run identity:verify && vite build && node scripts/app-fallbacks.mjs",
    "identity:build": "node scripts/build-identity-capsule.mjs",
    "identity:verify": "node scripts/build-identity-capsule.mjs --verify",
    "identity:check": "node scripts/build-identity-capsule.mjs --verify --check-sources --write-receipt",
    "app:package": "node scripts/package-app-bundle.mjs",
    "guard:canonical": "node scripts/canonical-deploy-guard.mjs",
    "audit:repos": "node scripts/local-repo-canonical-audit.mjs",
    "copy:audit": "node scripts/public-copy-audit.mjs",
    "deploy:preflight": "npm run guard:canonical && npm run copy:audit && npm run build && npm run site:worker:dry",
    "deploy:verify": "npm run smoke:interaction && npm run smoke:browser && npm run canary:prod && npm run redteam:prod-smoke && npm run qa:user-prompts && npm run qa:live-user",
    "amos:demo": "node scripts/amos-campaign-approval-demo.mjs",
    "amos:guard": "node scripts/amos-demo-guard.mjs && node scripts/amos-approval-console-smoke.mjs",
    "amos:approval-smoke": "node scripts/amos-approval-console-smoke.mjs",
    "amos:execution-gate": "node scripts/amos-execution-gate.mjs",
    "amos:queue": "node scripts/amos-task-queue.mjs",
    "amos:copy-sweep": "node scripts/amos-public-copy-friction-sweep.mjs",
    "amos:skill": "node scripts/amos-skill-contract.mjs",
    "preview": "vite preview",
    "cf:whoami": "node scripts/cloudflare-wrangler.mjs whoami",
    "cf:r2:list": "node scripts/cloudflare-wrangler.mjs r2 bucket list --config worker/wrangler.jsonc",
    "cf:r2:create:media": "node scripts/cloudflare-wrangler.mjs r2 bucket create active-mirror-media --config worker/wrangler.jsonc",
    "cf:kv:list": "node scripts/cloudflare-wrangler.mjs kv namespace list",
    "cf:kv:create:media": "node scripts/cloudflare-wrangler.mjs kv namespace create active-mirror-media --binding MIRROR_MEDIA_KV --config worker/wrangler.jsonc",
    "loops": "node scripts/task-loop.mjs list",
    "loops:match": "node scripts/task-loop.mjs match",
    "worker:dev": "node scripts/cloudflare-wrangler.mjs dev --config worker/wrangler.jsonc",
    "worker:deploy": "node scripts/cloudflare-wrangler.mjs deploy --config worker/wrangler.jsonc",
    "site:worker:dry": "node scripts/cloudflare-wrangler.mjs deploy --config wrangler.site.jsonc --dry-run",
    "site:worker:deploy": "node scripts/cloudflare-wrangler.mjs deploy --config wrangler.site.jsonc",
    "worker:types": "node scripts/cloudflare-wrangler.mjs types --config worker/wrangler.jsonc",
    "worker:test": "npm run identity:verify && node worker/test/mirror-kernel.test.mjs && node worker/test/gateway-guardrails.test.mjs && node worker/test/first-turn-quality.test.mjs && node scripts/conversation-quality-harness.mjs",
    "canary:prod": "node scripts/production-canary.mjs",
    "monitor:gateway": "node scripts/gateway-monitor.mjs",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "smoke:interaction": "node scripts/interaction-smoke.mjs",
    "qa:live-user": "node scripts/live-user-selftest.mjs",
    "qa:user-prompts": "node scripts/user-prompt-qa.mjs",
    "quality:conversation": "node scripts/conversation-quality-harness.mjs",
    "redteam:gateway": "node scripts/red-team-gateway.mjs",
    "redteam:local": "ACTIVE_MIRROR_GATEWAY=local-worker ACTIVE_MIRROR_RED_TEAM_DELAY_MS=0 node scripts/red-team-gateway.mjs",
    "redteam:live-local": "ACTIVE_MIRROR_GATEWAY=live-local ACTIVE_MIRROR_RED_TEAM_DELAY_MS=0 node scripts/red-team-gateway.mjs",
    "redteam:prod-smoke": "ACTIVE_MIRROR_RED_TEAM_TURNS=20 node scripts/red-team-gateway.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "gsap": "^3.15.0"
  }
}
